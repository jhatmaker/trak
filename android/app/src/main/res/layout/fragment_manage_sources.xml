<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="88dp">

            <!-- Section: Default sites -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sources_section_default"
                style="@style/Trak.SectionHeader"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sources_section_default_hint"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:paddingHorizontal="20dp"
                android:paddingBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                style="@style/Trak.Card">

                <LinearLayout
                    android:id="@+id/layout_default_sites"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </androidx.cardview.widget.CardView>

            <!-- Show hidden toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sources_show_hidden"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_show_hidden"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />

            </LinearLayout>

            <!-- Section: Custom sources -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sources_section_custom"
                style="@style/Trak.SectionHeader"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sources_section_custom_hint"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:paddingHorizontal="20dp"
                android:paddingBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                style="@style/Trak.Card">

                <LinearLayout
                    android:id="@+id/layout_custom_sources"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_custom_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sources_custom_empty"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- FAB: Add custom source -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_source"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="@string/sources_add_custom"
        app:icon="@android:drawable/ic_input_add"
        style="@style/Widget.MaterialComponents.ExtendedFloatingActionButton" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
