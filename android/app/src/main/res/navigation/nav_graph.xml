<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <!-- Dashboard -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.trackmyraces.trak.ui.dashboard.DashboardFragment"
        android:label="@string/nav_dashboard"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/action_dashboard_to_detail"
            app:destination="@id/resultDetailFragment" />

        <action
            android:id="@+id/action_dashboard_to_pending"
            app:destination="@id/pendingMatchesFragment" />

    </fragment>

    <!-- Pending Matches (sites where runner was found, awaiting confirmation) -->
    <fragment
        android:id="@+id/pendingMatchesFragment"
        android:name="com.trackmyraces.trak.ui.pending.PendingMatchesFragment"
        android:label="@string/pending_matches_title"
        tools:layout="@layout/fragment_pending_matches">

        <action
            android:id="@+id/action_pending_to_add"
            app:destination="@id/addResultFragment"
            app:popUpTo="@id/pendingMatchesFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- History -->
    <fragment
        android:id="@+id/historyFragment"
        android:name="com.trackmyraces.trak.ui.results.HistoryFragment"
        android:label="@string/nav_history"
        tools:layout="@layout/fragment_history">

        <action
            android:id="@+id/action_history_to_detail"
            app:destination="@id/resultDetailFragment" />

    </fragment>

    <!-- Discover (post-profile-setup: search popular sites for runner) -->
    <fragment
        android:id="@+id/discoverFragment"
        android:name="com.trackmyraces.trak.ui.discover.DiscoverFragment"
        android:label="@string/discover_title"
        tools:layout="@layout/fragment_discover">

        <argument
            android:name="runnerName"
            app:argType="string" />
        <argument
            android:name="dateOfBirth"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="interests"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="excludeSiteIds"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="sinceDate"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_discover_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/dashboardFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_discover_to_add"
            app:destination="@id/addResultFragment"
            app:popUpTo="@id/discoverFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- Add Result -->
    <fragment
        android:id="@+id/addResultFragment"
        android:name="com.trackmyraces.trak.ui.claims.AddResultFragment"
        android:label="@string/nav_add"
        tools:layout="@layout/fragment_add_result">

        <action
            android:id="@+id/action_add_to_detail"
            app:destination="@id/resultDetailFragment"
            app:popUpTo="@id/addResultFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_add_to_manual"
            app:destination="@id/manualEntryFragment" />

    </fragment>

    <!-- Manual Entry -->
    <fragment
        android:id="@+id/manualEntryFragment"
        android:name="com.trackmyraces.trak.ui.claims.ManualEntryFragment"
        android:label="@string/manual_entry_title"
        tools:layout="@layout/fragment_manual_entry">

        <action
            android:id="@+id/action_manual_to_detail"
            app:destination="@id/resultDetailFragment"
            app:popUpTo="@id/addResultFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- Profile -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.trackmyraces.trak.ui.profile.ProfileFragment"
        android:label="@string/nav_profile"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profile_to_discover"
            app:destination="@id/discoverFragment" />

        <action
            android:id="@+id/action_profile_to_manage_sources"
            app:destination="@id/manageSourcesFragment" />

        <action
            android:id="@+id/action_profile_to_dismissed"
            app:destination="@id/dismissedMatchesFragment" />

    </fragment>

    <!-- Manage Sources -->
    <fragment
        android:id="@+id/manageSourcesFragment"
        android:name="com.trackmyraces.trak.ui.sources.ManageSourcesFragment"
        android:label="@string/sources_title"
        tools:layout="@layout/fragment_manage_sources">

        <action
            android:id="@+id/action_manage_sources_to_discover"
            app:destination="@id/discoverFragment" />

        <action
            android:id="@+id/action_manage_sources_to_add"
            app:destination="@id/addResultFragment" />

        <action
            android:id="@+id/action_manage_sources_to_dismissed"
            app:destination="@id/dismissedMatchesFragment" />

    </fragment>

    <!-- Dismissed Matches -->
    <fragment
        android:id="@+id/dismissedMatchesFragment"
        android:name="com.trackmyraces.trak.ui.dismissed.DismissedMatchesFragment"
        android:label="@string/dismissed_title"
        tools:layout="@layout/fragment_dismissed_matches">

        <argument
            android:name="siteId"
            app:argType="string"
            android:defaultValue="" />

        <argument
            android:name="siteName"
            app:argType="string"
            android:defaultValue="" />

    </fragment>

    <!-- Result detail (navigated to from Dashboard, History, or Add) -->
    <fragment
        android:id="@+id/resultDetailFragment"
        android:name="com.trackmyraces.trak.ui.results.ResultDetailFragment"
        android:label="@string/detail_title"
        tools:layout="@layout/fragment_result_detail">

        <argument
            android:name="resultId"
            app:argType="string" />

        <action
            android:id="@+id/action_detail_to_edit"
            app:destination="@id/editResultFragment" />

    </fragment>

    <!-- Edit result — fill in or correct supplementary fields -->
    <fragment
        android:id="@+id/editResultFragment"
        android:name="com.trackmyraces.trak.ui.results.EditResultFragment"
        android:label="@string/edit_result_title"
        tools:layout="@layout/fragment_edit_result">

        <argument
            android:name="resultId"
            app:argType="string" />

        <action
            android:id="@+id/action_edit_to_map_picker"
            app:destination="@id/mapPickerFragment" />

    </fragment>

    <!-- Map location picker — drop a pin to get exact lat/lon for elevation + weather -->
    <fragment
        android:id="@+id/mapPickerFragment"
        android:name="com.trackmyraces.trak.ui.results.MapPickerFragment"
        android:label="@string/map_picker_title"
        tools:layout="@layout/fragment_map_picker" />

</navigation>
